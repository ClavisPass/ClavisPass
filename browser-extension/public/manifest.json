{
  "manifest_version": 3,
  "name": "ClavisPass",
  "description": "Secure password manager extension for ClavisPass.",
  "version": "0.1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "clavispass-extension@clavispass.local"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "ClavisPass",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "background/index.js",
    "scripts": ["background/index.js"],
    "type": "module"
  },
  "permissions": ["storage", "tabs", "scripting", "nativeMessaging"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/index.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ]
}
